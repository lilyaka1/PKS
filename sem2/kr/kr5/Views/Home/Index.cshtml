@{
    ViewData["Title"] = "Интерактивная система управления производством";
}

<section class="page-head">
    <div>
        <h1>Интерактивная система управления производством</h1>
    </div>
    <div class="head-actions">
        <button class="btn btn-outline-light" id="refreshBtn" type="button">Обновить данные</button>
    </div>
</section>

<div id="toast" class="toast-line" hidden></div>

<section class="dashboard-grid">
    <article class="panel panel-wide">
        <div class="panel-title">
            <div>
                <h2>Материалы</h2>
                <p>Складские остатки и быстрые пополнения</p>
            </div>
            <label class="toggle">
                <input type="checkbox" id="lowStockOnly">
                <span>Низкий запас</span>
            </label>
        </div>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Количество</th>
                        <th>Ед.</th>
                        <th>Действие</th>
                    </tr>
                </thead>
                <tbody id="materialsTable"></tbody>
            </table>
        </div>

        <form id="materialForm" class="inline-form">
            <input name="name" placeholder="Название" required>
            <input name="quantity" type="number" step="0.001" min="0" placeholder="Количество" required>
            <input name="unit" placeholder="Ед. изм." required>
            <input name="minStock" type="number" step="0.001" min="0" placeholder="Мин. запас" required>
            <button class="btn btn-primary" type="submit">Добавить</button>
        </form>
    </article>

    <article class="panel">
        <div class="panel-title">
            <div>
                <h2>Продукты</h2>
                <p>Категории, нормативы и материалы</p>
            </div>
        </div>

        <div class="filters">
            <select id="categoryFilter">
                <option value="">Все категории</option>
            </select>
            <input id="productSearch" placeholder="Поиск продукта">
        </div>

        <div class="table-wrap compact">
            <table>
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Мин/шт</th>
                        <th>Категория</th>
                    </tr>
                </thead>
                <tbody id="productsTable"></tbody>
            </table>
        </div>

        <form id="productForm" class="stack-form">
            <div class="two-cols">
                <input name="name" placeholder="Название продукта" required>
                <input name="prodTime" type="number" min="1" placeholder="Мин/шт" required>
            </div>
            <div class="two-cols">
                <input name="category" placeholder="Категория" required>
                <input name="minimalStock" type="number" min="0" placeholder="Мин. запас" value="0">
            </div>
            <textarea name="description" placeholder="Описание"></textarea>
            <textarea name="specifications" placeholder='{"параметр":"значение"}'>{}</textarea>
            <div id="productMaterials" class="material-picks"></div>
            <button class="btn btn-primary" type="submit">Создать продукт</button>
        </form>
    </article>

    <article class="panel">
        <div class="panel-title">
            <div>
                <h2>Заказы</h2>
                <p>Планирование и контроль выполнения</p>
            </div>
        </div>

        <form id="orderForm" class="stack-form">
            <select name="productId" id="orderProduct" required></select>
            <div class="two-cols">
                <input name="quantity" id="orderQuantity" type="number" min="1" value="1" required>
                <select name="lineId" id="orderLine"></select>
            </div>
            <input name="startDate" type="datetime-local">
            <div class="calculation" id="orderCalculation">Выберите продукт и линию</div>
            <button class="btn btn-primary" type="submit">Создать заказ</button>
        </form>

        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Номер</th>
                        <th>Продукт</th>
                        <th>Кол-во</th>
                        <th>Статус</th>
                        <th>Срок</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="ordersTable"></tbody>
            </table>
        </div>
    </article>

    <article class="panel panel-wide">
        <div class="panel-title">
            <div>
                <h2>Производственные линии</h2>
                <p>Состояние, эффективность и расписание</p>
            </div>
        </div>
        <div class="line-grid" id="linesGrid"></div>
    </article>
</section>

<dialog id="detailsDialog">
    <form method="dialog">
        <button class="dialog-close" aria-label="Закрыть">x</button>
    </form>
    <div id="detailsContent"></div>
</dialog>

@section Scripts {
    <script src="~/js/production.js" asp-append-version="true"></script>
}
</div>
