<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Туристический путеводитель</title>
    <style>
        :root {
            --c-whisper: #6FAFE3;
            --c-secret-soul: #7E8FE3;
            --c-endless-mist: #7FA9D8;
            --c-evening-glow: #91B7E6;
            --c-gentle-inspiration: #A4BBE1;
            --c-text-main: #1f2a3a;
            --c-text-soft: #3f5066;
            --c-surface: #f5f9ff;
            --c-card: #ffffff;
            --c-border: rgba(111, 175, 227, 0.25);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--c-surface);
            color: var(--c-text-main);
            line-height: 1.6;
        }
        header {
            background: var(--c-whisper);
            color: white;
            padding: 1rem 0;
            box-shadow: 0 4px 16px rgba(35, 59, 102, 0.18);
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        nav h1 {
            font-size: 1.5rem;
        }
        nav a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            transition: opacity 0.3s;
        }
        nav a:hover {
            opacity: 0.8;
        }
        main {
            min-height: calc(100vh - 150px);
            padding: 2rem 0;
        }
        footer {
            background: var(--c-secret-soul);
            color: white;
            text-align: center;
            padding: 1rem 0;
            margin-top: 2rem;
        }
        .card {
            background: var(--c-card);
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid var(--c-border);
            box-shadow: 0 6px 18px rgba(63, 80, 102, 0.08);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px rgba(63, 80, 102, 0.14);
        }
        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }
        .card-body {
            padding: 1.5rem;
        }
        .btn {
            display: inline-block;
            padding: 10px 20px;
            background: var(--c-secret-soul);
            color: white;
            text-decoration: none;
            border-radius: 5px;
            transition: opacity 0.3s;
            border: none;
            cursor: pointer;
        }
        .btn:hover {
            opacity: 0.9;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
        }
        .search-form {
            margin-bottom: 2rem;
            display: flex;
            gap: 10px;
        }
        .search-form input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid var(--c-border);
            border-radius: 5px;
            font-size: 1rem;
            background: #fff;
            color: var(--c-text-main);
        }
        .info-block {
            background: var(--c-card);
            padding: 2rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            border: 1px solid var(--c-border);
            box-shadow: 0 6px 18px rgba(63, 80, 102, 0.08);
        }
        .info-block img {
            max-width: 100%;
            border-radius: 10px;
            margin-bottom: 1rem;
        }
        .badge {
            display: inline-block;
            padding: 5px 10px;
            background: var(--c-endless-mist);
            color: white;
            border-radius: 20px;
            font-size: 0.85rem;
            margin-right: 10px;
        }
        .fallback-block {
            background: var(--c-evening-glow);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
        }
        .city-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 1rem;
        }
        .coat-of-arms {
            width: 68px;
            height: 82px;
            object-fit: contain;
            background: #eef4fd;
            border: 1px solid var(--c-border);
            border-radius: 10px;
            padding: 6px;
        }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <nav>
                <h1>Туристический путеводитель</h1>
                <div>
                    <a href="/Cities">Города</a>
                </div>
            </nav>
        </div>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 - Туристический путеводитель</p>
        </div>
    </footer>
</body>
</html>
