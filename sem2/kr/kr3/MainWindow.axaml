<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="HttpMonitorWpf.MainWindow"
        Title="KR3 HTTP Monitor"
        Width="1400"
        Height="920"
        MinWidth="1200"
        MinHeight="700"
        Background="#F3F6F9"
        FontFamily="Inter, Segoe UI"
        mc:Ignorable="d"
        d:DesignWidth="1400"
        d:DesignHeight="920">

    <Window.Resources>
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B5D7A" Offset="0" />
            <GradientStop Color="#0F766E" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="CardBrush" Color="#FCFEFF" />
        <SolidColorBrush x:Key="SoftBrush" Color="#EEF4F8" />
        <SolidColorBrush x:Key="MainText" Color="#0F172A" />
        <SolidColorBrush x:Key="MutedText" Color="#475569" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#DDE8F2" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#BFD2E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0E625D" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#FEE2E2" />
            <Setter Property="Foreground" Value="#991B1B" />
            <Setter Property="BorderBrush" Value="#FCA5A5" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#C5D4E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#C5D4E2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" CornerRadius="12" Padding="12" BoxShadow="0 4 12 0 #22415A55">
            <StackPanel Spacing="2">
                <TextBlock Text="HTTP Monitor" FontSize="22" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Мониторинг входящих и исходящих запросов" FontSize="11" Foreground="#D7F4EF" />
            </StackPanel>
        </Border>

        <!-- Управление -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="10" BoxShadow="0 2 8 0 #1A334144">
            <Grid ColumnDefinitions="Auto,85,Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                <TextBlock VerticalAlignment="Center" Text="Порт:" FontWeight="SemiBold" FontSize="11" />
                <TextBox x:Name="PortTextBox" Grid.Column="1" Text="8080" Watermark="8080" />
                <Button x:Name="StartServerButton" Grid.Column="2" Classes="accent" Content="Start" Click="StartServerClick" Width="90" />
                <Button x:Name="StopServerButton" Grid.Column="3" Classes="danger" Content="Stop" Click="StopServerClick" IsEnabled="False" Width="90" />
                <Button x:Name="ClearLogsButton" Grid.Column="4" Content="Clear Logs" Click="ClearLogsClick" Width="95" />
                <TextBlock x:Name="ServerStateTextBlock" Grid.Column="5" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#0B5D7A" Text="Stopped" FontSize="11" />
                <TextBlock x:Name="UptimeText" Grid.Column="6" VerticalAlignment="Center" Text="00:00:00" Foreground="{StaticResource MutedText}" FontSize="11" />
                <TextBlock Grid.Column="7" />
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="2" ColumnDefinitions="1.3*,*" ColumnSpacing="10">
            <!-- Логи -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="10">
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="10" BoxShadow="0 2 8 0 #1A334144">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                        <TextBlock Text="Statistics" FontSize="12" FontWeight="SemiBold" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Border Background="{StaticResource SoftBrush}" CornerRadius="8" Padding="6">
                                <StackPanel>
                                    <TextBlock Text="Всего" Foreground="{StaticResource MutedText}" FontSize="10" />
                                    <TextBlock x:Name="TotalRequestsText" Text="0" FontSize="16" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource SoftBrush}" CornerRadius="8" Padding="6">
                                <StackPanel>
                                    <TextBlock Text="GET" Foreground="{StaticResource MutedText}" FontSize="10" />
                                    <TextBlock x:Name="GetRequestsText" Text="0" FontSize="16" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="{StaticResource SoftBrush}" CornerRadius="8" Padding="6">
                                <StackPanel>
                                    <TextBlock Text="POST" Foreground="{StaticResource MutedText}" FontSize="10" />
                                    <TextBlock x:Name="PostRequestsText" Text="0" FontSize="16" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="{StaticResource SoftBrush}" CornerRadius="8" Padding="6">
                                <StackPanel>
                                    <TextBlock Text="Ср. (мс)" Foreground="{StaticResource MutedText}" FontSize="10" />
                                    <TextBlock x:Name="AvgMsText" Text="0" FontSize="16" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,120,Auto,120,*" ColumnSpacing="8">
                            <TextBlock VerticalAlignment="Center" Text="Метод:" FontWeight="SemiBold" FontSize="10" />
                            <ComboBox x:Name="MethodFilterComboBox" Grid.Column="1" SelectionChanged="FilterChanged" SelectedIndex="0">
                                <ComboBoxItem Content="Все" />
                                <ComboBoxItem Content="GET" />
                                <ComboBoxItem Content="POST" />
                            </ComboBox>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="Статус:" FontWeight="SemiBold" FontSize="10" />
                            <ComboBox x:Name="StatusFilterComboBox" Grid.Column="3" SelectionChanged="FilterChanged" SelectedIndex="0">
                                <ComboBoxItem Content="Все" />
                                <ComboBoxItem Content="2xx" />
                                <ComboBoxItem Content="4xx" />
                                <ComboBoxItem Content="5xx" />
                            </ComboBox>
                        </Grid>
                        <TextBlock Grid.Row="3" Text="Request Logs" FontSize="12" FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <TextBox Grid.Row="1"
                         x:Name="LogsTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="10"
                         Background="{StaticResource CardBrush}"
                         BorderBrush="#C5D4E2"
                         BorderThickness="1"
                         CornerRadius="10"
                         Padding="8"
                         MinHeight="350" />
            </Grid>

            <!-- Клиент и график -->
            <Grid Grid.Column="1" RowDefinitions="Auto,1*,1*" RowSpacing="10">
                <!-- Клиент -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="10" BoxShadow="0 2 8 0 #1A334144">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                        <TextBlock Text="HTTP Client" FontSize="12" FontWeight="SemiBold" />
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                            <TextBlock VerticalAlignment="Center" Text="URL:" FontWeight="SemiBold" FontSize="10" />
                            <TextBox x:Name="ClientUrlTextBox" Grid.Column="1" Text="https://jsonplaceholder.typicode.com/posts" />
                        </Grid>
                        <Grid Grid.Row="2" ColumnDefinitions="Auto,100,*" ColumnSpacing="6">
                            <TextBlock VerticalAlignment="Center" Text="Method:" FontWeight="SemiBold" FontSize="10" />
                            <ComboBox x:Name="ClientMethodComboBox" Grid.Column="1" SelectedIndex="0">
                                <ComboBoxItem Content="GET" />
                                <ComboBoxItem Content="POST" />
                            </ComboBox>
                        </Grid>
                        <TextBlock Grid.Row="3" Text="Body (JSON):" FontWeight="SemiBold" FontSize="10" />
                        <TextBox Grid.Row="4"
                                 x:Name="ClientBodyTextBox"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MinHeight="45"
                                 >{"message": "hello"}</TextBox>
                        <Button Grid.Row="5" HorizontalAlignment="Left" Classes="accent" Content="Send Request" Click="SendRequestClick" Padding="8,4" Width="110" />
                    </Grid>
                </Border>

                <!-- Ответ -->
                <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="10" BoxShadow="0 2 8 0 #1A334144">
                    <Grid RowDefinitions="Auto,*" RowSpacing="6">
                        <TextBlock Text="Response" FontWeight="SemiBold" FontSize="12" />
                        <TextBox Grid.Row="1"
                                 x:Name="ClientResponseTextBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="9"
                                 MaxHeight="140" />
                    </Grid>
                </Border>

                <!-- График -->
                <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="10" Padding="10" BoxShadow="0 2 8 0 #1A334144">
                    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                            <TextBlock VerticalAlignment="Center" Text="Load Chart:" FontWeight="SemiBold" FontSize="12" />
                            <ComboBox x:Name="ChartRangeComboBox" Grid.Column="1" SelectedIndex="0" SelectionChanged="ChartRangeChanged">
                                <ComboBoxItem Content="По минутам" />
                                <ComboBoxItem Content="По часам" />
                            </ComboBox>
                        </Grid>
                        <TextBlock Grid.Row="1" x:Name="ChartSummaryText" Foreground="{StaticResource MutedText}" Text="Нет данных" FontSize="10" />
                        <Border Grid.Row="2" Background="{StaticResource SoftBrush}" CornerRadius="8" Padding="6" MinHeight="150">
                            <Canvas x:Name="LoadChartCanvas" SizeChanged="LoadChartSizeChanged" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="3" HorizontalAlignment="Right" Foreground="#94A3B8" Text="" FontSize="9" />
    </Grid>
</Window>
